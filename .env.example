# Copy to `.env` and adjust. `.env` is gitignored.
# Models & endpoints are injected — no opinion on the provider in the code.
# genai routes model names to the right adapter; LLM and embeddings may live on
# different providers/hosts.

# --- LLM (chat) ---
# Provider: `ollama` (local, uses ENKI_LLM_ENDPOINT) or a genai-native provider
# routed by model name: `gemini`, `openai`, `anthropic`, … Cloud providers read
# their own API key from env (GEMINI_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY)
# and ignore ENKI_LLM_ENDPOINT.
ENKI_LLM_PROVIDER=ollama
ENKI_LLM_MODEL=llama3.1
ENKI_LLM_ENDPOINT=http://localhost:11434/
# Cloud API key, injected via config (a desktop app sets Config.llm_api_key from
# its own settings/keychain — no process env needed). If unset, genai falls back
# to the provider's own env var (GEMINI_API_KEY / OPENAI_API_KEY / …).
# ENKI_LLM_API_KEY=
# Example — Gemini as a reference LLM (embedder stays Ollama below):
#   ENKI_LLM_PROVIDER=gemini
#   ENKI_LLM_MODEL=gemini-2.5-flash
#   ENKI_LLM_API_KEY=...        # or GEMINI_API_KEY=...

# --- Embeddings (may differ from the LLM; e.g. Anthropic has no embeddings) ---
# Keep this on the provider/model the index was built with — changing it
# invalidates the persisted vectors.
ENKI_EMBED_PROVIDER=ollama
ENKI_EMBED_MODEL=bge-m3
ENKI_EMBED_ENDPOINT=http://localhost:11434/
# ENKI_EMBED_API_KEY=   # only for a cloud embedder

# --- Corpus ---
# Document manifest: hierarchical outline (sections: title/level/pages/content).
ENKI_MANIFEST=data/document.manifest.json
# Static per-library scope injected into the system prompt (what this library is about).
ENKI_LIBRARY_SCOPE=

# --- Retrieval knobs ---
ENKI_TOP_K=5
ENKI_MAX_ROUNDS=6
# Store backend: local | qdrant  (qdrant needs `--features qdrant`)
#   local  — on-disk vectors + brute-force, zero infra (ENKI_CACHE_DIR)
#   qdrant — a Qdrant server, read + write (ENKI_QDRANT_URL)
ENKI_BACKEND=local
ENKI_CACHE_DIR=.cache
# Qdrant backend (used only when ENKI_BACKEND=qdrant):
ENKI_QDRANT_URL=http://localhost:6334
# ENKI_QDRANT_API_KEY=          # Qdrant Cloud only
# Sparse (lexical) driver → hybrid dense+sparse collection. Qdrant-only.
#   none     — dense-only (default)
#   hashed   — zero-dep hashed TF (server applies IDF); multilingual, wasm-safe
#   fastembed — learned sparse (needs --features fastembed); ENKI_SPARSE_MODEL below
ENKI_SPARSE=none
# For ENKI_SPARSE=fastembed: bge-m3 (multilingual, default) | splade (English)
ENKI_SPARSE_MODEL=bge-m3
# Server-side fusion of the dense + sparse branches: rrf (default) | dbsf
ENKI_QDRANT_FUSION=rrf
# Lexical (BM25) backend: none | tantivy  (needs `--features tantivy`)
# Local backend only — incompatible with ENKI_BACKEND=qdrant (dense-only for now).
ENKI_LEXICAL=none
# Reranker backend: none | fastembed  (needs `--features fastembed`)
ENKI_RERANK=none
# Optional: reuse an existing reranker model cache instead of downloading.
# ENKI_RERANK_CACHE=/path/to/model/cache

# --- Observability ---
# tracing filter for the console sink: info (default) | enki=debug | off
ENKI_LOG=info
